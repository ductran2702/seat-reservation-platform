# Copy to .env: cp .env.example .env

# --- Database (matches infra/docker-compose.yml; host port 5434 to avoid local conflicts) ---
DATABASE_URL="postgresql://seat:seat@localhost:5434/seat_reservation?schema=public"
POSTGRES_PASSWORD=seat
# Read replica for non-critical SELECTs (optional — falls back to DATABASE_URL).
# TODO(prod): point at a Postgres read replica once provisioned — no code change needed.
DATABASE_READ_URL=
# Direct-to-primary connection for the seat-svc sweeper. Advisory locks are
# session-level, so this must bypass PgBouncer (optional — falls back to DATABASE_URL).
SWEEPER_DATABASE_URL=

# --- Services ---
NODE_ENV=development
GATEWAY_PORT=3000
AUTH_SVC_PORT=3001
SEAT_SVC_PORT=3002
PAYMENT_SVC_PORT=3003
AUTH_SVC_URL=http://localhost:3001
SEAT_SVC_URL=http://localhost:3002
PAYMENT_SVC_URL=http://localhost:3003
GATEWAY_URL=http://localhost:3000
# Authenticates gateway → service traffic; services only trust X-User-Id with it.
INTERNAL_SECRET="dev_internal_secret"
WEB_ORIGIN=http://localhost:5174

# --- Auth ---
# Use long random strings in any real environment.
ACCESS_TOKEN_SECRET="dev_access_secret_change_me"
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=90

# --- Booking ---
# How long a seat hold lasts before it expires (set low to test the expiry path).
HOLD_TTL_SECONDS=30
SEAT_PRICE_CENTS=2500
MAX_ACTIVE_RESERVATIONS_PER_USER=2
# Background hold-expiry sweeper interval (seat-svc).
SWEEP_INTERVAL_MS=10000

# --- Redis (optional — seat cache and SSE TODOs no-op when unset) ---
REDIS_URL=

# --- Demo user (created by the seed script) ---
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=password123
