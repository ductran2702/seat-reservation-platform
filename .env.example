# Copy to .env: cp .env.example .env

# --- Database (matches docker-compose.yml; host port 5434 to avoid local conflicts) ---
DATABASE_URL="postgresql://seat:seat@localhost:5434/seat_reservation?schema=public"

# --- Server ---
PORT=4001
NODE_ENV=development
WEB_ORIGIN=http://localhost:5174

# --- Auth ---
# Use a long random string in any real environment.
# (Refresh tokens are opaque random values tracked in the DB — no secret needed.)
ACCESS_TOKEN_SECRET="dev_access_secret_change_me"
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=90

# --- Booking ---
# How long a seat hold lasts before it expires (set low to test the expiry path).
HOLD_TTL_SECONDS=30
SEAT_PRICE_CENTS=2500
# Max simultaneous active (held or confirmed) reservations per user.
MAX_ACTIVE_RESERVATIONS_PER_USER=2

# --- Demo user (created by the seed script) ---
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=password123
