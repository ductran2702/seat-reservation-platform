generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReservationStatus {
  HELD
  CONFIRMED
  EXPIRED
  CANCELLED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  TIMEOUT
}

enum OutboxStatus {
  PENDING
  PROCESSED
  DEAD
}

// Transactional outbox (payment-svc, Pattern B): events are written in the
// SAME transaction as the business mutation, so a crash can never confirm a
// payment without enqueueing its event (or vice versa). A poll worker
// delivers them at-least-once and only marks PROCESSED after success;
// poisoned events go to DEAD after max attempts instead of blocking the queue.
model OutboxEvent {
  id          String       @id @default(cuid())
  type        String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, createdAt])
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  // Embedded in every access token (`ver` claim) and bumped on logout /
  // refresh-token reuse, so a stolen access JWT dies immediately instead of
  // staying valid until its 15m expiry.
  tokenVersion Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  reservations Reservation[]
  refreshTokens RefreshToken[]
}

model Seat {
  id           String        @id @default(cuid())
  label        String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
}

model Reservation {
  id            String            @id @default(cuid())
  seat          Seat              @relation(fields: [seatId], references: [id])
  seatId        String
  user          User              @relation(fields: [userId], references: [id])
  userId        String
  status        ReservationStatus @default(HELD)
  // Client-generated key so retried POSTs (double-click, network blip) map to
  // the same reservation instead of creating duplicates.
  idempotencyKey String?          @unique
  holdExpiresAt DateTime
  confirmedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  payment       Payment?

  // NOTE: the "one active reservation per seat" guarantee is a PARTIAL unique
  // index (status IN ('HELD','CONFIRMED')) that Prisma cannot express in the
  // schema. It is applied via prisma/partial-index.sql during `db:push`.
  @@index([seatId])
  @@index([userId])
  @@index([status])
}

model Payment {
  id            String        @id @default(cuid())
  reservation   Reservation   @relation(fields: [reservationId], references: [id])
  reservationId String        @unique
  amountCents   Int
  status        PaymentStatus @default(PENDING)
  outcome       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model RefreshToken {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}
